# Glass Ledger on Vercel — every one of these is read at BUILD time, not at run time.
#
# `NEXT_PUBLIC_*` values are inlined into the bundle by `next build`. Changing one in the Vercel
# dashboard therefore does nothing until the project is REDEPLOYED — a restart will not pick it up,
# and the app will keep serving whatever it was built with.
#
# Copy these into Vercel → Settings → Environment Variables (Production, and Preview if you want
# previews to work), then deploy.

# ── Which chain the shop is ────────────────────────────────────────────────────────────────────────
# This is load-bearing twice over. It selects the deployment addresses AND it is checked against the
# consignment at build time: build for one chain with another chain's paperwork and the app does not
# break, it LIES — every genuine tag is reported to the reader as a forgery, because the vouchers it
# names were published to a store this chain never wrote to. `sync-artifacts.mjs` refuses the build
# rather than let that ship.
NEXT_PUBLIC_CHAIN_ID=16602

# ── Where the shop's paperwork is ──────────────────────────────────────────────────────────────────
# The consignment for chain 16602, committed to the repo so Vercel's checkout can see it. Without
# this the build finds no consignment, says so quietly, and deploys an empty shelf.
GLASS_DATA_DIR=artifacts/demo/16602

# ── The chain ──────────────────────────────────────────────────────────────────────────────────────
# 0G Galileo's public RPC. Every figure on the site is read from here by the reader's own browser —
# no server of ours sits in between, which is the entire point.
NEXT_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai

# ── The vouchers ───────────────────────────────────────────────────────────────────────────────────
# On a public chain the voucher bytes live in 0G Storage, not on this origin. With this set to "0g"
# the browser fetches each one from the 0G indexer by its pointer and hashes it itself. Leave it
# unset and the app looks for the bytes under /blobs, finds nothing, and condemns every tag.
NEXT_PUBLIC_STORAGE=0g

# ── The catalog ────────────────────────────────────────────────────────────────────────────────────
# The off-chain grouping: which units make up which product, and what they are called. HTTPS, because
# a page served over HTTPS cannot fetch http:// — the browser blocks it as mixed content and the
# product names silently vanish.
#
# This service is NOT load-bearing. If it is down the shop loses its names and nothing else; the
# ledger, the shelf, and every item, debt and claim are read straight from the chain.
NEXT_PUBLIC_INDEXER_URL=https://glass.16.171.44.97.sslip.io
